<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Relay Bridge LaunchAgent template.
  Polls Fly.io relay for Telegram messages and forwards to local gateway.
  Starts on boot, restarts on crash, survives sleep/wake cycles.

  1. Replace YOUR_USERNAME with your macOS username (whoami)
  2. Save to ~/Library/LaunchAgents/ai.openclaw.relay-bridge.plist
  3. Load: launchctl load ~/Library/LaunchAgents/ai.openclaw.relay-bridge.plist
-->
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>ai.openclaw.relay-bridge</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>ProgramArguments</key>
    <array>
      <string>/opt/homebrew/bin/python3</string>
      <string>/Users/YOUR_USERNAME/.openclaw/scripts/relay-bridge.py</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/YOUR_USERNAME/.openclaw/logs/relay-bridge.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_USERNAME/.openclaw/logs/relay-bridge.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>HOME</key>
      <string>/Users/YOUR_USERNAME</string>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
  </dict>
</plist>
